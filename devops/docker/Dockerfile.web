FROM node:20-alpine AS base
RUN corepack enable && corepack prepare pnpm@10 --activate
WORKDIR /app

FROM base AS dependencies
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml .npmrc ./
COPY artifacts/intro-video/package.json artifacts/intro-video/
RUN pnpm install --frozen-lockfile --prod=false

FROM dependencies AS build
COPY tsconfig.base.json tsconfig.json ./
COPY artifacts/intro-video/ artifacts/intro-video/
RUN pnpm --filter @workspace/intro-video run build

FROM nginx:1.27-alpine AS production
RUN addgroup -g 1001 -S appgroup && adduser -S appuser -u 1001 -G appgroup

COPY devops/docker/nginx.conf /etc/nginx/nginx.conf
COPY --from=build --chown=appuser:appgroup /app/artifacts/intro-video/dist/ /usr/share/nginx/html/

EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=5s --start-period=5s --retries=3 \
  CMD wget --no-verbose --tries=1 --spider http://localhost:8080/ || exit 1

CMD ["nginx", "-g", "daemon off;"]
